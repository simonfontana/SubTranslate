{
  "manifest_version": 2,
  "name": "SubTranslate",
  "version": "1.7.0",
  "description": "Click a word in video subtitles to translate it using DeepL.",
  "permissions": [
    "activeTab",
    "storage",
    "https://api-free.deepl.com/*",
    "https://api.deepl.com/*"
  ],
  "icons": {
    "16": "src/icons/icon16.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "background": {
    "scripts": [
      "src/constants.js",
      "src/utils.js",
      "src/background.js"
    ],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://www.svtplay.se/*"
      ],
      "js": [
        "src/constants.js",
        "src/utils.js",
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{8bd18a9d-3fe6-4c5c-ba1b-421513d1ad74}",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  },
  "browser_action": {
    "default_title": "SubTranslate",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "48": "src/icons/icon48.png",
      "128": "src/icons/icon128.png"
    }
  }
}
